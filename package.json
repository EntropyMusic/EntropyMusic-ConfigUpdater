{
  "name": "entropymusic-firmware",
  "version": "0.1.4",
  "description": "Standalone Electron app for the Entropy Music firmware configurator (firmware page only).",
  "main": "main.js",
  "author": "Entropy Music LLC",
  "license": "PolyForm-Noncommercial-1.0.0",
  "private": true,
  "scripts": {
    "sync": "node scripts/sync-firmware.mjs",
    "prestart": "npm run sync",
    "start": "electron .",
    "pack": "npm run sync && electron-builder --dir",
    "dist": "npm run sync && electron-builder",
    "dist:mac": "npm run sync && electron-builder --mac",
    "dist:win": "npm run sync && electron-builder --win",
    "dist:linux": "npm run sync && electron-builder --linux",
    "release": "node scripts/release.mjs"
  },
  "build": {
    "appId": "cc.entropymusic.firmware",
    "productName": "Entropy Music Firmware",
    "artifactName": "EntropyMusicFirmware-${version}-${arch}.${ext}",
    "electronLanguages": [
      "en",
      "en_GB",
      "zh_CN",
      "zh_TW"
    ],
    "afterPack": "scripts/afterPack.js",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://entropymusic.cc/updates/"
      }
    ],
    "mac": {
      "category": "public.app-category.music",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "dmg": {
      "format": "ULFO",
      "contents": [
        {
          "x": 130,
          "y": 220,
          "type": "file",
          "path": "scripts/fix-gatekeeper.command"
        },
        {
          "x": 250,
          "y": 220,
          "type": "file"
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Audio"
    }
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
